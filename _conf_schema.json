{
  "enable_nickname": {
    "type": "bool",
    "description": "显示用户昵称",
    "default": false
  },
  "welcome_message": {
    "type": "string",
    "description": "入群欢迎模板（变量：{user_id}、{nickname}、{group_id}、{way}、{inviter_id}）",
    "default": "🎉 欢迎新成员 {nickname}！({way})"
  },
  "leave_message": {
    "type": "string",
    "description": "退群通知模板（变量：{user_id}、{nickname}、{group_id}、{reason}、{operator_id}）",
    "default": "👋 成员 {nickname} 已{reason}"
  },
  "napcat_http_host": {
    "type": "string",
    "description": "NapCat HTTP 服务地址（默认 127.0.0.1）",
    "default": "127.0.0.1"
  },
  "napcat_http_port": {
    "type": "int",
    "description": "NapCat HTTP 服务端口（默认 3000）",
    "default": 3000,
    "minimum": 1,
    "maximum": 65535
  }
}